uint8_t nextWorld [ROWS][COLS];

// Define a variable to store the number of living neighbors
int neighborCount;

// Creating the TFT object (display)
Adafruit_ILI9341 tft = Adafruit_ILI9341(TFT_CS, TFT_DC);

void setup() {
  // Define input pins, i.e., control buttons
  pinMode(buttonAPin, INPUT_PULLUP); // Button A must be defined as INPUT_PULLUP
  pinMode(colorButtonPin, INPUT);
  pinMode(patternButtonPin, INPUT);
  // Display initialization
  tft.begin();
  // Setting the display orientation
  tft.setRotation(3);
  // Define background color (black consumes the least power)
  tft.fillScreen(ILI9341_BLACK);
  // Call the function to draw the grid
  drawGrid();
}

void loop() {
  // If the START button is pressed, the program will skip
  // the neighbor calculation function and only draw
  // the current game state 
  if (digitalRead(buttonAPin) == HIGH) {
    // Call the function to calculate neighbors
    calculateNextGeneration();
    // Draw the current game state
    drawGrid();
  }
   else {
    // Draw the current game state
    drawGrid();
  }
  // If the up button is pressed, randomly select a cell color
  if (digitalRead(colorButtonPin) == HIGH) {
    cellColor=int(random(65535));
  }
  // If the VOL. button is pressed, randomly select cell states
  // THIS ACTUALLY ACTS AS A WORLD //RESET// and the game starts from the beginning
  if (digitalRead(patternButtonPin) == HIGH) {
    initializeGrid();
  }
}

void drawGrid(){
  // Drawing the current game state
  // Set coordinates to the corner of the display
  uint16_t x=0;
  uint16_t y=0;
  
  for (uint8_t i = 0; i < ROWS; i++){
    x=0;
    for (uint8_t j = 0; j < COLS; j++){
      // If the value is TRUE, draw the cell in color 
      if (world[i][j] == 1) tft.fillRect(x,y,CELL_SIZE,CELL_SIZE, cellColor);             
      // If the value is something other than TRUE, draw the cell in the black background color
      else                  tft.fillRect(x,y,CELL_SIZE,CELL_SIZE,ILI9341_BLACK);      
      // Increase x by the scale factor
      x+=SCALE_FACTOR;    
    }
    // Increase y by the scale factor, i.e., go to the next row
    y+=SCALE_FACTOR;    
  }  
}

void initializeGrid(){
  // Random initialization of the game cells
  // First we must reset the random seed so we don't always get the same patterns
  randomSeed(analogRead(0));
  // Then fill the array with the random function
  for (uint8_t i = 0; i< ROWS; i++){
    for (uint8_t j = 0; j< COLS; j++){
      world[i][j]=int(random(2));
    }
  }
  // We will display the result of the array
  drawGrid();
  delay(2000);
}

void applyNextGeneration(){
  // Now we need to make a copy of the world for further processing
  for (uint8_t i = 0; i< ROWS; i++){
    for (uint8_t j = 0; j< COLS; j++){
      world[i][j]=nextWorld[i][j];    
    }
  }
}

void calculateNextGeneration(){
  // The following lines of code will calculate how many neighbors each cell has
  for (int i = 1; i< ROWS-1; i++){
    for (int j = 1; j< COLS-1; j++){
      neighborCount=0;
      for (int k = -1; k <=1; k++){
        for (int l = -1; l<= 1; l++){
          neighborCount += world[i+k][j+l];
        }
      }
      neighborCount -= world[i][j];
      if      ((world[i][j] == 1) && (neighborCount <  2)) nextWorld[i][j]=0;
      else if ((world[i][j] == 1) && (neighborCount >= 4)) nextWorld[i][j]=0;
      else if ((world[i][j] == 0) && (neighborCount == 3)) nextWorld[i][j]=1;
      else                                             nextWorld[i][j]=world[i][j];
    }
  }
  applyNextGeneration();
}